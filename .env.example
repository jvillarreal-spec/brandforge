# Database (Vercel Postgres - automatically set when linked)
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# Auth
JWT_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# AI (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# S3 Storage (optional - for asset uploads)
# S3_BUCKET_NAME=brandforge-assets
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
